# Copy to .env.local and fill in your credentials

PORT=3000

# LiveKit — https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Memgraph (Bolt protocol) — defaults to localhost:7687
MEMGRAPH_HOST=your-memgraph-host-or-ip
MEMGRAPH_PORT=7687
MEMGRAPH_USER=
MEMGRAPH_PASS=

# Resend — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_EMAIL_ADDRESS=noreply@yourdomain.com

# App public URL (used in email links)
APP_URL=http://localhost:3000

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Temporal — local Docker stack (localhost:7233)
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_API_KEY=

# Shared secret for Temporal worker → server internal API calls
WORKER_INTERNAL_SECRET=change-me-in-production
