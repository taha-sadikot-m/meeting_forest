{
  "name": "meeting-forest",
  "version": "1.0.0",
  "description": "LiveKit meeting room platform built with Bun",
  "main": "index.ts",
  "scripts": {
    "start": "bun run index.ts",
    "worker": "bun run src/temporal/worker.ts",
    "dev": "bun --hot run index.ts",
    "dev:all": "bun run index.ts & bun run src/temporal/worker.ts"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@livekit/rtc-node": "^0.13.30",
    "@temporalio/activity": "^1.19.0",
    "@temporalio/client": "^1.19.0",
    "@temporalio/worker": "^1.19.0",
    "@temporalio/workflow": "^1.19.0",
    "livekit-client": "^2.20.0",
    "livekit-server-sdk": "^2.9.0",
    "neo4j-driver": "^6.1.0",
    "resend": "^6.14.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
